# ─── Entorno ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Base de datos (PostgreSQL / Supabase) ────────────────────────────────────
# Opción A: connection string completa (Render, Railway, Supabase pooler)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_bd

# Opción B: variables individuales (desarrollo local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blackmichiestudio
DB_USER=postgres
DB_PASSWORD=

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<proyecto>.supabase.co
SUPABASE_SERVICE_KEY=          # service_role key — solo backend, nunca expongas al cliente
SUPABASE_BUCKET=BlackMichiEstudio

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
RENDER_EXTERNAL_URL=           # solo en producción (Render lo inyecta automáticamente)

# ─── Flow (pagos) ─────────────────────────────────────────────────────────────
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_ENV=sandbox               # sandbox | production

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
