# ─── SERVIDOR ────────────────────────────────────────────────────────────────
NODE_ENV=development           # development | production
PORT=3000

# ─── BASE DE DATOS ───────────────────────────────────────────────────────────
# Opción A — URL completa (Supabase / Render / Railway) — tiene prioridad
DATABASE_URL=postgresql://usuario:password@host:5432/blackmichiestudio

# Opción B — variables individuales (Docker local)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=blackmichiestudio
# DB_USER=postgres
# DB_PASSWORD=

# ─── SUPABASE AUTH ───────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=          # service_role key — SOLO backend, nunca al cliente

# ─── CLOUDINARY (imágenes) ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── FLOW (pasarela de pago) ─────────────────────────────────────────────────
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_ENV=sandbox               # sandbox | production

# ─── URLS ────────────────────────────────────────────────────────────────────
# BACKEND_URL: URL pública que Flow usa para webhooks — debe ser HTTPS en producción
BACKEND_URL=http://localhost:3000
# FRONTEND_URL: URL pública del frontend — para redirecciones post-pago de Flow
FRONTEND_URL=http://localhost:5173

# ─── GOOGLE AUTH ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=              # OAuth 2.0 Client ID de Google Cloud Console

# ─── RENDER (producción) ─────────────────────────────────────────────────────
# Render inyecta estas variables automáticamente — no las agregues a mano
# RENDER=true
# RENDER_EXTERNAL_URL=https://tu-app.onrender.com
